# Core Engine Configuration
# Copy this file to .env and fill in your provider credentials.

# ============================================================
# OPTION A: Direct Anthropic API
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# OPTION B: AWS Bedrock
# ============================================================
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1

# Bedrock authentication (choose one method):

# Method 1: Bedrock API Key (simplest)
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key

# Method 2: AWS Access Keys
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=optional-session-token

# Method 3: AWS Profile (uses ~/.aws/credentials)
# AWS_PROFILE=your-profile-name

# ============================================================
# Model Override (optional)
# ============================================================
# Bedrock model IDs use a different format:
# ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ============================================================
# Platform Settings
# ============================================================
# PREWARM_POOL_SIZE=2
# MAX_SESSIONS=10
# PROJECT_CWD=.
# LOG_LEVEL=INFO
# CORS_ORIGINS=*
